<dashboard version="1.1" theme="dark">
  <label>SOC Lab - Attack Detection</label>
  <description>
    SOC Lab - Multi-stage attack detection dashboard monitoring SSH brute force,
    unauthorized access attempts, and compromise indicators from a controlled red team simulation.
  </description>

  <!-- Panel 1: Nmap Recon -->
  <row>
    <panel>
      <chart>
        <title>Nmap Reconnaissance Activity</title>
        <search>
          <query>
            index=linux sourcetype=linux_secure
            | search _raw="*scan*" OR "*nmap*" OR "*port*"
            | timechart span=1h count as "Reconnaissance Events"
          </query>
          <earliest>-2d</earliest>
          <latest></latest>
        </search>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.seriesColors">[0x6B4FBB]</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>

    <!-- Panel 2: SSH Brute Force -->
    <panel>
      <chart>
        <title>SSH Brute Force Attempts</title>
        <search>
          <query>
            index=linux sourcetype=linux_secure "Failed password"
            | timechart span=1h count as "Failed Attempts"
          </query>
          <earliest>-2d</earliest>
          <latest></latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.seriesColors">[0xE8273C]</option>
      </chart>
    </panel>
  </row>

  <!-- Panel 3: Totals -->
  <row>
    <panel>
      <single>
        <title>Total Failed Login Attempts</title>
        <search>
          <query>
            index=linux sourcetype=linux_secure "Failed password"
            | stats count as "Failed Attempts"
          </query>
          <earliest>-2d</earliest>
          <latest></latest>
        </search>
        <option name="drilldown">none</option>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0xE8273C","0xE8273C"]</option>
        <option name="refresh.display">progressbar</option>
      </single>
    </panel>

    <panel>
      <single>
        <title>Successful Logins Detected</title>
        <search>
          <query>
            index=linux sourcetype=linux_secure "Accepted password"
            | stats count as "Successful Logins"
          </query>
          <earliest>-2d</earliest>
          <latest></latest>
        </search>
        <option name="drilldown">none</option>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="rangeColors">["0xFF6B35","0xFF6B35"]</option>
        <option name="refresh.display">progressbar</option>
      </single>
    </panel>
  </row>

  <!-- Panel 4: Timeline -->
  <row>
    <panel>
      <table>
        <title>Full Attack Timeline</title>
        <search>
          <query>
            index=linux sourcetype=linux_secure ("Failed password" OR "Accepted password")
            | eval status=if(match(_raw,"Failed"),"FAILED","SUCCESS")
            | table _time, host, status, _raw
            | sort _time
          </query>
          <earliest>-2d</earliest>
          <latest></latest>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>

</dashboard>